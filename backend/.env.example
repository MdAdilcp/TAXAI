# TaxAI Backend — copy to .env and fill values

# Security (required)
SECRET_KEY=4f9c8d7a3e6b2c1f9a8d7e6c5b4a3f2d8c7e6b5a4f3c2d1e9a8b7c6d5e4f3a2b
ENCRYPTION_KEY=4f9c8d7a3e6b2c1f9a8d7e6c5bjjk4a3f2d8c7e6b5a4f3c29a8b7c6d5e4f3a2b


# Google Cloud (OCR; optional: Translate, TTS)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project

# LLM
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini
LLM_PROVIDER=openrouter

# OCR
OCR_PROVIDER=openrouter
OCR_LLM_PROVIDER=openrouter
OCR_LLM_MODEL=openai/gpt-4o-mini
OCR_ENABLE_LLM_REFINE=true
OCR_PREPROCESS_SCANS=true
GEMINI_OCR_MODEL=gemini-2.0-flash
OCR_MAX_PDF_TEXT_PAGES=8
OCR_MAX_PDF_OCR_PAGES=3
OCR_MAX_IMAGE_VARIANTS=2
OCR_TARGET_CHARS=1800
OCR_FAST_ACCEPT_SCORE=108
OCR_OPENROUTER_TIMEOUT_SEC=12
OCR_OPENROUTER_RETRIES=1
OCR_OPENROUTER_MAX_MODELS=1

# ERI e-filing sandbox
ERI_SANDBOX_BASE_URL=https://eportal.incometax.gov.in/ero/sandbox
ERI_CLIENT_ID=your-eri-client-id
ERI_CLIENT_SECRET=your-eri-client-secret

# PAN verification (NSDL/Protean)
PAN_VERIFICATION_URL=
PAN_API_KEY=

# GST GSP (business income)
GST_GSP_BASE_URL=

# Translation & TTS
TRANSLATE_API=google
TTS_PROVIDER=google

# Database (optional; default SQLite for MVP)
DATABASE_URL=sqlite+aiosqlite:///./taxai.db

# Aadhaar — only if authorized
UIDAI_SANDBOX_URL=
UIDAI_AUA_CODE=
